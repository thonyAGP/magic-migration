{
  "domain": "accountMerge",
  "domainPascal": "AccountMerge",
  "complexity": "MEDIUM",
  "entities": [
    {
      "name": "MergeHistory",
      "fields": [
        {
          "name": "id",
          "type": "number",
          "source": "histo_fusionseparation.id",
          "nullable": false
        },
        {
          "name": "sourceAccount",
          "type": "string",
          "source": "histo_fusionseparation.compte_source",
          "nullable": false
        },
        {
          "name": "targetAccount",
          "type": "string",
          "source": "histo_fusionseparation.compte_cible",
          "nullable": false
        },
        {
          "name": "mergeDate",
          "type": "Date",
          "source": "histo_fusionseparation.date_fusion",
          "nullable": false
        },
        {
          "name": "operator",
          "type": "string",
          "source": "histo_fusionseparation.operateur",
          "nullable": false
        },
        {
          "name": "status",
          "type": "string",
          "source": "histo_fusionseparation.statut",
          "nullable": false
        }
      ]
    },
    {
      "name": "Account",
      "fields": [
        {
          "name": "accountNumber",
          "type": "string",
          "source": "compte_gm.numero_compte",
          "nullable": false
        },
        {
          "name": "balance",
          "type": "number",
          "source": "compte_gm.solde",
          "nullable": false
        },
        {
          "name": "status",
          "type": "string",
          "source": "compte_gm.statut",
          "nullable": false
        },
        {
          "name": "createdDate",
          "type": "Date",
          "source": "compte_gm.date_creation",
          "nullable": false
        }
      ]
    },
    {
      "name": "MergeValidation",
      "fields": [
        {
          "name": "isClosureInProgress",
          "type": "boolean",
          "source": "reseau_cloture.en_cours",
          "nullable": false
        },
        {
          "name": "networkStatus",
          "type": "string",
          "source": "w0_reseau",
          "nullable": false
        },
        {
          "name": "validationStatus",
          "type": "string",
          "source": "w0_validation",
          "nullable": false
        }
      ]
    }
  ],
  "stateFields": [
    {
      "name": "mergeHistories",
      "type": "MergeHistory[]",
      "default": "[]"
    },
    {
      "name": "sourceAccount",
      "type": "Account | null",
      "default": "null"
    },
    {
      "name": "targetAccount",
      "type": "Account | null",
      "default": "null"
    },
    {
      "name": "validationState",
      "type": "MergeValidation | null",
      "default": "null"
    },
    {
      "name": "isLoading",
      "type": "boolean",
      "default": "false"
    },
    {
      "name": "error",
      "type": "string | null",
      "default": "null"
    },
    {
      "name": "mergeProgress",
      "type": "number",
      "default": "0"
    },
    {
      "name": "currentStep",
      "type": "string",
      "default": "'validation'"
    }
  ],
  "actions": [
    {
      "name": "validateMergeConditions",
      "params": [
        "sourceAccountId: string",
        "targetAccountId: string"
      ],
      "businessRules": [
        "Verify closure not in progress (W0 validation != 'V')",
        "Check network status (W0 reseau != 'R')",
        "Validate account states before merge"
      ],
      "returns": "Promise<void>"
    },
    {
      "name": "executeMerge",
      "params": [
        "sourceAccountId: string",
        "targetAccountId: string"
      ],
      "businessRules": [
        "Transfer all transactions from source to target account",
        "Update account balances and status",
        "Create merge history record",
        "Generate merge completion log"
      ],
      "returns": "Promise<void>"
    },
    {
      "name": "createMergeHistory",
      "params": [
        "sourceAccount: string",
        "targetAccount: string",
        "operator: string"
      ],
      "businessRules": [
        "Record merge operation in history table",
        "Set merge timestamp and operator",
        "Track merge status progression"
      ],
      "returns": "Promise<void>"
    },
    {
      "name": "rollbackMerge",
      "params": [
        "mergeHistoryId: number"
      ],
      "businessRules": [
        "Restore original account states",
        "Reverse transaction transfers",
        "Update merge history with rollback status"
      ],
      "returns": "Promise<void>"
    },
    {
      "name": "printMergeTicket",
      "params": [
        "mergeHistoryId: number"
      ],
      "businessRules": [
        "Generate merge completion ticket",
        "Include source and target account details",
        "Show transaction summary and timestamps"
      ],
      "returns": "Promise<void>"
    }
  ],
  "apiEndpoints": [
    {
      "method": "GET",
      "path": "/api/accountMerge/validation",
      "queryParams": [
        "sourceAccountId",
        "targetAccountId"
      ],
      "response": "MergeValidation"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/execute",
      "queryParams": [],
      "response": "MergeHistory"
    },
    {
      "method": "GET",
      "path": "/api/accountMerge/history",
      "queryParams": [
        "accountId?",
        "dateFrom?",
        "dateTo?"
      ],
      "response": "MergeHistory[]"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/rollback",
      "queryParams": [],
      "response": "Promise<void>"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/print-ticket",
      "queryParams": [],
      "response": "Promise<void>"
    }
  ],
  "uiLayout": {
    "type": "wizard-form",
    "sections": [
      {
        "name": "accountSelection",
        "controls": [
          "sourceAccountInput",
          "targetAccountInput",
          "accountValidationButton"
        ]
      },
      {
        "name": "validationStatus",
        "controls": [
          "closureStatusIndicator",
          "networkStatusIndicator",
          "validationResultPanel"
        ]
      },
      {
        "name": "mergeExecution",
        "controls": [
          "progressBar",
          "currentStepIndicator",
          "executeMergeButton",
          "cancelButton"
        ]
      },
      {
        "name": "completion",
        "controls": [
          "mergeResultSummary",
          "printTicketButton",
          "closeButton"
        ]
      }
    ]
  },
  "mockData": {
    "count": 5,
    "description": "Sample account merge operations with various statuses (completed, in-progress, failed) including validation states, merge histories, and associated account details"
  },
  "dependencies": {
    "stores": [
      "useAccountStore",
      "useValidationStore",
      "useHistoryStore"
    ],
    "sharedTypes": [
      "Account",
      "ValidationStatus",
      "NetworkStatus"
    ],
    "externalApis": [
      "printingService",
      "networkValidationService"
    ]
  }
}